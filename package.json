{
  "name": "@kadanza/extension-sdk",
  "version": "0.0.5",
  "description": "Helpers for building extensions",
  "keywords": [
    "kadanza",
    "sdk",
    "extension",
    "browser"
  ],
  "homepage": "https://github.com/kadanza-io/extension-sdk#readme",
  "bugs": {
    "url": "https://github.com/kadanza-io/extension-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kadanza-io/extension-sdk.git"
  },
  "license": "MIT",
  "author": "Kadanza team",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/extension-sdk.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/extension-sdk.cjs"
      }
    }
  },
  "main": "./dist/extension-sdk.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.lib.json --noEmit && vite build",
    "preview": "vite preview",
    "docs": "typedoc",
    "docs:check": "typedoc --emit none",
    "check:types": "npx --yes @arethetypeswrong/cli --pack .",
    "prepublishOnly": "npm run build && npm run check:types"
  },
  "devDependencies": {
    "typedoc": "^0.28.20",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "sideEffects": false,
  "module": "./dist/extension-sdk.js"
}
